# Anthropic API キー (台本生成に必要)
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-...

# --- 動画生成 (--build-video) で使うキー -----------------------------
# Pexels: 無料ストック画像 (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Nano Banana = Gemini 画像生成 (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# OpenAI gpt-image-1 (provider: openai を選んだときだけ必要)
OPENAI_API_KEY=

# ffmpeg のフルパス。PATH に通っていれば未設定でOK
# 例 (Windows): C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_BIN=
