# 台本生成 (必須)
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-...

# --- 収集ソース別の API キー --------------------------------------------

# ⑧ YouTube Data API v3 (https://console.cloud.google.com/)
# 未設定なら YouTube collector は自動 skip
YOUTUBE_API_KEY=

# ⑩ X (旧 Twitter) API Basic — 月 $200 課金が必要 (https://developer.x.com/)
# 未設定なら X collector は自動 skip
X_BEARER_TOKEN=

# ⑫ Bluesky (https://bsky.app/settings/app-passwords でアプリパスワード作成)
# 未設定なら Bluesky collector は自動 skip
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
